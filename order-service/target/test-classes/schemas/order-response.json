{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderResponse",
  "type": "object",
  "required": ["id", "userId", "productId", "quantity",
               "totalPrice", "status", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "userId": {
      "type": "string",
      "minLength": 1
    },
    "productId": {
      "type": "string",
      "minLength": 1
    },
    "quantity": {
      "type": "integer",
      "minimum": 1
    },
    "totalPrice": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "status": {
      "type": "string",
      "enum": ["PENDING", "CONFIRMED", "SHIPPED", "CANCELLED"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}